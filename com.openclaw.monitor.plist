<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.openclaw.monitor</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>/Users/minimo/Documents/ClawMonitor/server.js</string>
  </array>
  <key>StandardOutPath</key>
  <string>/Users/minimo/.openclaw/logs/monitor.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/minimo/.openclaw/logs/monitor.err.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>/Users/minimo</string>
    <key>PORT</key>
    <string>7842</string>
  </dict>
</dict>
</plist>
